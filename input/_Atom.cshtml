@using Wyam.Feeds
<?xml version="1.0" encoding="utf-8"?>
<feed xmlns="http://www.w3.org/2005/Atom">
  <title type="text">@Context.GlobalMetadata.String(DocsKeys.Title)</title>
  <subtitle type="text">@Context.GlobalMetadata.String(DocsKeys.Description)</subtitle>
  <id>@Context.GetLink("/", true)</id>
  <updated>@DateTime.UtcNow.ToString("yyyy-MM-ddTHH:mm:ssZ")</updated>
  <link rel="alternate" type="text/html" href="@Context.GetLink("/", true)" />
  <link rel="self" type="application/atom+xml" href="@Context.GetLink(Model, true)" />
  @foreach(IDocument post in Documents[Docs.BlogPosts].Take(20))
  {
  <entry>
    <id>@Context.GetLink(post, true)</id>
    <title type="text">@post.String(BlogKeys.Title)</title>
    <updated>@(post.Get<DateTime>(BlogKeys.Published).ToString("yyyy-MM-ddTHH:mm:ssZ"))</updated>
    <link rel="alternate" type="text/html" href="@Context.GetLink(post, true)" />
    <content type="html">@Html.Raw(post.Content)</content>
  </entry>
  }
</feed>
